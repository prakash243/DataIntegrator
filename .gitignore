# =============================================================================
# Data Integrator — .gitignore (Production)
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
env/
ENV/
.venv/
.env.venv/
virtualenv/
pyvenv.cfg

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# SQLite databases — production should use Postgres/MySQL; never commit DBs
*.sqlite3
*.sqlite3-journal
*.db
db.sqlite3
db.sqlite3-journal

# User-uploaded media files — production should use S3/external storage
media/
uploads/

# Collected static files (generated by collectstatic)
staticfiles/
static_root/
static_collected/

# Django secret key and local settings
local_settings.py
settings_local.py
.env
.env.*
!.env.example
!.env.sample

# Django migrations — ONLY ignore if intentional (usually committed)
# Uncomment the following only if your project uses migration-less workflow:
# */migrations/*.py
# !*/migrations/__init__.py

# Django logs
*.log
logs/
django.log
celery.log
gunicorn.log

# Celery
celerybeat-schedule
celerybeat.pid

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.cache/
.pytest_cache/
.hypothesis/
nosetests.xml
*.cover
*.py,cover
.benchmarks/

# -----------------------------------------------------------------------------
# Type checkers & linters
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
.pylintrc.d/

# -----------------------------------------------------------------------------
# Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# IDE & editors
# -----------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/settings.json.sample
!.vscode/extensions.json
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*.swn
*~
.*.swp
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Emacs
*~
\#*\#
.\#*
.emacs.desktop
.emacs.desktop.lock

# Eclipse
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Never commit override files with secrets
docker-compose.override.yml
docker-compose.*.local.yml
.dockerignore.local

# Docker volumes and data
.docker/
docker-data/

# -----------------------------------------------------------------------------
# Secrets & credentials (CRITICAL — never commit these)
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.cert
*.cer
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.asc
*.gpg

secrets/
secret.*
credentials.json
service-account*.json
google-credentials.json
aws-credentials
.aws/
.netrc

# API keys / tokens
*.token
api-keys.txt
tokens.txt

# -----------------------------------------------------------------------------
# Dependency lock files (project-specific — keep or remove as appropriate)
# -----------------------------------------------------------------------------
# Pipenv
Pipfile.lock

# Poetry — usually committed, uncomment to ignore
# poetry.lock

# PDM
.pdm.toml
.pdm-python
.pdm-build/

# -----------------------------------------------------------------------------
# Build artifacts & compiled files
# -----------------------------------------------------------------------------
*.tar
*.tar.gz
*.zip
*.7z
*.rar
*.bz2
*.gz

# -----------------------------------------------------------------------------
# Temporary & backup files
# -----------------------------------------------------------------------------
*.bak
*.backup
*.tmp
*.temp
*.orig
*.swp
tmp/
temp/

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
# Conversion job output files (regenerated from user uploads)
media/conversions/

# Claude / AI assistant artifacts
.claude/
.cursor/
.aider*
.continue/

# Local sample / scratch files
scratch/
playground/
local_test_*.py
test_local_*.py
*_local.py
